# Test Environment Template
# Copy this file to `.env.test` locally and replace placeholder values before running tests.

# PostgreSQL Test Database
POSTGRESQL_URL=postgresql://testuser:<set-test-postgres-password>@localhost:5433/tournament_test
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=tournament_test
POSTGRES_USER=testuser
POSTGRES_PASSWORD=<set-test-postgres-password>

# Redis Test Cache
REDIS_URL=redis://:<set-test-redis-password>@localhost:6380/0
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=<set-test-redis-password>

# Redis Streams Test Cache
REDIS_STREAMS_URL=redis://:<set-test-redis-streams-password>@localhost:6381/0
REDIS_STREAMS_PASSWORD=<set-test-redis-streams-password>

# Kafka Test Broker
KAFKA_BOOTSTRAP_SERVERS=localhost:9093
KAFKA_HOST=localhost
KAFKA_PORT=9093

# Test Configuration
PYTHONPATH=/root/samchat/src
ENVIRONMENT=test
DEBUG=false
